# OmniD3sk — Helpdesk & Productivity Orchestrator
# Copy this file to .env and fill in your values

# Google Cloud
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1

# Model (Gemini Live for voice, Flash for ADK text chat)
MODEL=gemini-live-2.5-flash-native-audio
ADK_MODEL=gemini-2.5-flash
RESEARCH_MODEL=gemini-2.5-flash

# Enable ADK multi-agent orchestration
ENABLE_ADK=false

# Session settings
SESSION_TIME_LIMIT=300

# Server
PORT=8080

# SQLite DB path (default: omniflow.db in project root)
OMNIFLOW_DB_PATH=omniflow.db

# ── MCP: Google Calendar Integration ────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_FILE=gcp-key.json
CALENDAR_ID=primary

# ── MCP: Notion Integration ─────────────────────────────────────────────────
NOTION_API_KEY=secret_your_notion_integration_token_here
NOTION_PAGE_ID=your_notion_page_id_here

# ── Multi-Tenant: MongoDB ────────────────────────────────────────────────────
# MongoDB Atlas connection string (get from atlas.mongodb.com → Connect → Drivers)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/omnid3sk?retryWrites=true&w=majority
MONGODB_DB_NAME=omnid3sk

# ── Multi-Tenant: Google OAuth 2.0 ──────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Application type: Web application
# Authorised redirect URI: http://localhost:8080/api/auth/google/callback
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Base URL of the frontend (used to redirect after OAuth)
# Dev:        http://localhost:3000/
# Prod/SPA:   /
FRONTEND_URL=http://localhost:3000/

# ── Multi-Tenant: JWT ────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY_SECONDS=86400
